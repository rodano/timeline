{
	"compilerOptions": {
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"checkJs": true,
		"moduleResolution": "node",
		"target": "ESNext",
		"module": "ESNext",
		"noEmit": true,
		"skipLibCheck": true,
		"lib": [
			"ESNext",
			"DOM"
		],
	},
	"exclude": [
		"node_modules",
		"dist",
		"webpack.config.js"
	]
}
